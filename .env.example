IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password
IMAP_FOLDER=INBOX
BRAVOS_SENDER_FILTER=bravosresearch.com

BROWSER_PROFILE_DIR=.browser_profile

POLL_INTERVAL_SECONDS=60
SIGNALS_DB_PATH=signals.db

# --- Phase 2: IBKR + Telegram ---

# "primary" gateway — Jon's own accounts (TFSA/RRSP/Non-reg/etc), one login.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=17
IBKR_WATCHER_CLIENT_ID=18

# "wife" gateway — a separate IBKR login, needs its own headless Gateway
# process on a different port. Not needed until that account exists.
IBKR_WIFE_HOST=127.0.0.1
IBKR_WIFE_PORT=4003
IBKR_WIFE_CLIENT_ID=27
IBKR_WIFE_WATCHER_CLIENT_ID=28

# Per-account config — see accounts.example.json. Copy to accounts.json and
# fill in real account IDs, capital allocation, and Quant/Tactical split.
ACCOUNTS_CONFIG_PATH=accounts.json

# One weight point = this fraction of an account's *allocated* capital
# (weight 5 * 0.02 = 10% of what's allocated to that account/strategy, not
# the whole account). Confirm the right multiplier before trading live.
WEIGHT_UNIT_PCT=0.02

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Comma-separated — every signal and fill notification goes to all of these.
TELEGRAM_CHAT_IDS=your_chat_id,another_chat_id

APPROVAL_POLL_INTERVAL_SECONDS=30
